// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                 @id @default(uuid())
  name                   String
  email                  String                 @unique
  password               String
  createdAt              DateTime               @default(now())
  categories             Category[]
  transactions           Transaction[]
  financialAccounts      FinancialAccount[]
  transfers              Transfer[]
  balanceAdjustments     BalanceAdjustment[]
  reminders              Reminder[]
  statementImportBatches StatementImportBatch[]
  statementImportFiles   StatementImportFile[]
  importedMovements      ImportedMovement[]
}

model Category {
  id                      String             @id @default(uuid())
  name                    String
  icon                    String?
  kind                    CategoryKind       @default(BOTH)
  isArchived              Boolean            @default(false)
  userId                  String
  user                    User               @relation(fields: [userId], references: [id])
  transactions            Transaction[]
  reminders               Reminder[]
  reviewImportedMovements ImportedMovement[] @relation("ImportedMovementReviewCategory")
  createdAt               DateTime           @default(now())

  @@index([userId, isArchived])
}

enum TransactionType {
  CREDIT_CASH
  CREDIT_INSTALLMENT
  DEBIT
  CASH
  PIX
  INCOME
}

enum CategoryKind {
  EXPENSE
  INCOME
  BOTH
}

enum FinancialAccountType {
  BANK_ACCOUNT
  CASH_WALLET
  OTHER
}

enum ReminderStatus {
  PENDING
  DONE
  CANCELED
}

enum StatementProvider {
  NUBANK
  INTER
  ITAU
  SANTANDER
  BRADESCO
  CAIXA
  BB
  C6
  MERCADO_PAGO
  UNKNOWN
}

enum StatementSourceType {
  PDF
  CSV
  XLSX
  OFX
}

enum StatementImportBatchStatus {
  DRAFT
  REVIEWING
  READY
  APPLIED
  PARTIALLY_APPLIED
  CANCELED
}

enum StatementImportFileStatus {
  PARSED
  DUPLICATE
  FAILED
}

enum StatementMovementDirection {
  IN
  OUT
}

enum ImportedMovementStatus {
  NEW
  DUPLICATE
  IGNORED
  READY
  NEEDS_REVIEW
  APPLIED
}

enum ImportedMovementReviewTarget {
  TRANSACTION
  TRANSFER
}

enum ImportedMovementReconciliationStatus {
  PENDING
  CONFIRMED_UNIQUE
  CONFIRMED_DUPLICATE
}

model FinancialAccount {
  id                    String                @id @default(uuid())
  name                  String
  type                  FinancialAccountType  @default(BANK_ACCOUNT)
  institutionName       String?
  icon                  String?
  color                 String?
  initialBalance        Decimal               @default(0) @db.Decimal(10, 2)
  includeInDashboard    Boolean               @default(true)
  isArchived            Boolean               @default(false)
  userId                String
  user                  User                  @relation(fields: [userId], references: [id])
  transactions          Transaction[]
  outgoingTransfers     Transfer[]            @relation("OutgoingTransfers")
  incomingTransfers     Transfer[]            @relation("IncomingTransfers")
  balanceAdjustments    BalanceAdjustment[]
  reminders             Reminder[]
  statementImportFiles  StatementImportFile[]
  reviewTransferImports ImportedMovement[]    @relation("ImportedMovementReviewTransferAccount")
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([userId])
  @@index([userId, isArchived])
}

model Transaction {
  id                 String             @id @default(uuid())
  type               TransactionType
  amount             Decimal            @db.Decimal(10, 2)
  date               DateTime
  isPending          Boolean            @default(false)
  description        String?
  totalInstallments  Int?
  currentInstallment Int?
  installmentGroupId String?
  categoryId         String
  category           Category           @relation(fields: [categoryId], references: [id])
  financialAccountId String
  financialAccount   FinancialAccount   @relation(fields: [financialAccountId], references: [id])
  userId             String
  user               User               @relation(fields: [userId], references: [id])
  importedMovements  ImportedMovement[] @relation("ImportedMovementAppliedTransaction")
  createdAt          DateTime           @default(now())

  @@index([financialAccountId])
}

model Transfer {
  id                String             @id @default(uuid())
  amount            Decimal            @db.Decimal(10, 2)
  date              DateTime
  isPending         Boolean            @default(false)
  description       String?
  fromAccountId     String
  fromAccount       FinancialAccount   @relation("OutgoingTransfers", fields: [fromAccountId], references: [id])
  toAccountId       String
  toAccount         FinancialAccount   @relation("IncomingTransfers", fields: [toAccountId], references: [id])
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  importedMovements ImportedMovement[] @relation("ImportedMovementAppliedTransfer")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([userId])
  @@index([fromAccountId])
  @@index([toAccountId])
}

model BalanceAdjustment {
  id                 String           @id @default(uuid())
  amount             Decimal          @db.Decimal(10, 2)
  date               DateTime
  reason             String
  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id])
  userId             String
  user               User             @relation(fields: [userId], references: [id])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([userId])
  @@index([financialAccountId])
  @@index([userId, date])
}

model Reminder {
  id                 String            @id @default(uuid())
  title              String
  dueDate            DateTime
  amount             Decimal?          @db.Decimal(10, 2)
  status             ReminderStatus    @default(PENDING)
  note               String?
  financialAccountId String?
  financialAccount   FinancialAccount? @relation(fields: [financialAccountId], references: [id])
  categoryId         String?
  category           Category?         @relation(fields: [categoryId], references: [id])
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([financialAccountId])
  @@index([categoryId])
}

model StatementImportBatch {
  id        String                     @id @default(uuid())
  status    StatementImportBatchStatus @default(REVIEWING)
  userId    String
  user      User                       @relation(fields: [userId], references: [id])
  files     StatementImportFile[]
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
}

model StatementImportFile {
  id                  String                    @id @default(uuid())
  originalName        String
  mimeType            String
  size                Int
  provider            StatementProvider
  sourceType          StatementSourceType
  fileHash            String
  status              StatementImportFileStatus @default(PARSED)
  duplicateOfFileId   String?
  duplicateOfFile     StatementImportFile?      @relation("DuplicateStatementImportFile", fields: [duplicateOfFileId], references: [id])
  duplicateFiles      StatementImportFile[]     @relation("DuplicateStatementImportFile")
  accountNumber       String?
  periodStart         DateTime?
  periodEnd           DateTime?
  openingBalanceCents Int?
  closingBalanceCents Int?
  totalInCents        Int?
  totalOutCents       Int?
  warnings            Json?
  batchId             String
  batch               StatementImportBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  financialAccountId  String?
  financialAccount    FinancialAccount?         @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  userId              String
  user                User                      @relation(fields: [userId], references: [id])
  movements           ImportedMovement[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([batchId])
  @@index([financialAccountId])
  @@index([duplicateOfFileId])
  @@index([userId, fileHash])
  @@index([userId, provider, sourceType, accountNumber, periodStart, periodEnd], map: "StatementImportFile_dedupe_period_idx")
}

model ImportedMovement {
  id                       String                               @id @default(uuid())
  date                     DateTime
  direction                StatementMovementDirection
  amountCents              Int
  rawType                  String
  rawDescription           String
  normalizedDescription    String
  sourcePage               Int?
  sourceLine               Int?
  fingerprint              String
  externalId               String?
  status                   ImportedMovementStatus               @default(NEW)
  reviewTarget             ImportedMovementReviewTarget         @default(TRANSACTION)
  reviewCategoryId         String?
  reviewCategory           Category?                            @relation("ImportedMovementReviewCategory", fields: [reviewCategoryId], references: [id], onDelete: SetNull)
  reviewTransferAccountId  String?
  reviewTransferAccount    FinancialAccount?                    @relation("ImportedMovementReviewTransferAccount", fields: [reviewTransferAccountId], references: [id], onDelete: SetNull)
  reconciliationStatus     ImportedMovementReconciliationStatus @default(PENDING)
  reconciliationNote       String?
  reconciliationReviewedAt DateTime?
  appliedTransactionId     String?
  appliedTransaction       Transaction?                         @relation("ImportedMovementAppliedTransaction", fields: [appliedTransactionId], references: [id], onDelete: SetNull)
  appliedTransferId        String?
  appliedTransfer          Transfer?                            @relation("ImportedMovementAppliedTransfer", fields: [appliedTransferId], references: [id], onDelete: SetNull)
  appliedAt                DateTime?
  fileId                   String
  file                     StatementImportFile                  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId                   String
  user                     User                                 @relation(fields: [userId], references: [id])
  createdAt                DateTime                             @default(now())
  updatedAt                DateTime                             @updatedAt

  @@index([fileId])
  @@index([userId, fingerprint])
  @@index([userId, externalId])
  @@index([userId, status])
  @@index([userId, reconciliationStatus])
  @@index([reviewCategoryId])
  @@index([reviewTransferAccountId])
  @@index([appliedTransactionId])
  @@index([appliedTransferId])
  @@index([date])
}
